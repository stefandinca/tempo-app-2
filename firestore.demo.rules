rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // DEMO RULES - Permissive for showcasing all features
    // Only requirement: Must be signed in (anonymous or authenticated)

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Core Collections ---

    match /team_members/{memberId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read, write: if isSignedIn();
    }

    match /events/{eventId} {
      allow read, write: if isSignedIn();
    }

    match /services/{serviceId} {
      allow read, write: if isSignedIn();
    }

    match /programs/{programId} {
      allow read, write: if isSignedIn();
    }

    match /system_settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isSignedIn();
    }

    match /payouts/{payoutId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read, write: if isSignedIn();
    }

    // --- Client Subcollections ---

    match /clients/{clientId}/evaluations/{evalId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId}/vbmapp_evaluations/{evalId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId}/portage_evaluations/{evalId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId}/cars_evaluations/{evalId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId}/carolina_evaluations/{evalId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId}/interventionPlans/{planId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId}/homework/{homeworkId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId}/documents/{documentId} {
      allow read, write: if isSignedIn();
    }

    match /clients/{clientId}/reports/{reportId} {
      allow read, write: if isSignedIn();
    }

    // --- Communication ---

    match /fcm_tokens/{userId} {
      allow read, write: if isSignedIn();
    }

    match /threads/{threadId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Reference Data ---

    match /evaluation_protocols/{protocolId=**} {
      allow read, write: if isSignedIn();
    }

    // --- Leads & Expenses ---

    match /potential_clients/{leadId} {
      allow read, write: if true; // Public form submission
    }

    match /expenses/{expenseId} {
      allow read, write: if isSignedIn();
    }

    match /recurring_expenses/{configId} {
      allow read, write: if isSignedIn();
    }

    // --- Activity Logging ---

    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      // Activities are immutable - no updates/deletes even in demo
      allow update, delete: if false;
    }

    // --- Collection Group Rules ---

    match /{path=**}/interventionPlans/{planId} {
      allow read: if isSignedIn();
    }
  }
}
